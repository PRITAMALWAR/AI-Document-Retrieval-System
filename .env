import { PDFLoader } from "@langchain/community/document_loaders/fs/pdf";
import { RecursiveCharacterTextSplitter } from "@langchain/textsplitters";
import { Pinecone } from "@pinecone-database/pinecone";
import OpenAI from "openai";
import "dotenv/config";

async function indexing() {

    // =========================
    // Load PDF
    // =========================

    console.log("Loading PDF...");

    const pdfLoader = new PDFLoader("./Node.pdf");
    const rawDocs = await pdfLoader.load();

    // =========================
    // Create Chunks
    // =========================

    const splitter = new RecursiveCharacterTextSplitter({
        chunkSize: 1000,
        chunkOverlap: 200,
    });

    const chunkedDocs = await splitter.splitDocuments(rawDocs);

    console.log("Total Chunks:", chunkedDocs.length);

    // =========================
    // NVIDIA Client
    // =========================

    const client = new OpenAI({
        apiKey: process.env.NVIDIA_API_KEY,
        baseURL: "https://integrate.api.nvidia.com/v1",
    });

    // =========================
    // Pinecone Connection
    // =========================

    const pinecone = new Pinecone({
        apiKey: process.env.PINECONE_API_KEY,
    });

    const index = pinecone.index(
        process.env.PINECONE_INDEX_NAME
    );

    console.log("Pinecone Connected");

    // =========================
    // Loop Through All Chunks
    // =========================

    for (let i = 0; i < chunkedDocs.length; i++) {

        console.log(`Creating Embedding ${i + 1}/${chunkedDocs.length}`);

        // Generate embedding
        const embeddingResponse = await client.embeddings.create({
            model: "nvidia/llama-nemotron-embed-1b-v2",
            input: chunkedDocs[i].pageContent,
            input_type: "passage",
        });

        const vector = embeddingResponse.data[0].embedding;

        // Create record
        const record = {
            id: `chunk-${i}`,
            values: vector,
            metadata: {
                text: chunkedDocs[i].pageContent,
                page: chunkedDocs[i].metadata.loc?.pageNumber || 1,
                source: "Node.pdf",
            },
        };

        // Store in Pinecone
        await index.upsert({
            records: [record],
        });

          // Show progress every 10 chunks
    if ((i + 1) % 10 === 0 || i === chunkedDocs.length - 1) {
        console.log(`Progress: ${i + 1}/${chunkedDocs.length}`);
    }
    }

    console.log("All Chunks Stored Successfully");
}

indexing().catch((error) => {
    console.error(error);
});